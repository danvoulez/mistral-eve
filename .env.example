DATABASE_URL=
BETTER_AUTH_SECRET=
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Required: file uploads use Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Optional: override the app origin for a custom production domain.
BETTER_AUTH_URL=

# Optional: enable hosted Vercel Connect integrations.
SLACK_CONNECTOR=
LINEAR_CONNECTOR=
NOTION_CONNECTOR=
SENTRY_CONNECTOR=

# Optional: generate embeddings for the knowledge base with OpenAI.
# Required when using the `search_knowledge_base` tool.
OPENAI_API_KEY=

# Optional: secret for the external webhook that creates tasks and notifications.
WEBHOOK_SECRET=

# Optional: send OpenTelemetry traces to a custom OTLP endpoint.
# Vercel auto-configures OTel when no endpoint is set.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional: Dynamic Projections motor (lib/projections).
# Base URL do runtime de projeção; o reader fala POST <url>/projection (modo rows).
# Sem isso, o motor degrada para cenas vazias com warnings de fonte parcial.
DREAM_MACHINE_RUNTIME_URL=
# Bearer opcional para o /projection (leitura; zero capacidade de escrita).
DREAM_MACHINE_RUNTIME_TOKEN=
# Timeout do reader em ms (default 8000).
DREAM_MACHINE_RUNTIME_TIMEOUT_MS=

# Optional: seam do Lab (autoridade). A tool propose_effect despacha POST <url>/effect
# após aprovação humana (airlock). Sem isso, a intenção é aprovada mas não despachada.
DREAM_MACHINE_LAB_URL=
DREAM_MACHINE_LAB_TOKEN=
DREAM_MACHINE_LAB_TIMEOUT_MS=
